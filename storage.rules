rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'mahfujar003@gmail.com' ||
        request.auth.token.email_verified == true
      );
    }
  }
}
