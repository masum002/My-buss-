{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "orderID": { "type": "string" },
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "discountAmount": { "type": "number" },
        "couponCode": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["COD", "Manual"] },
        "paymentGateway": { "type": "string", "enum": ["bKash", "Nagad", "Rocket", "None"] },
        "transactionID": { "type": "string" },
        "screenshotURL": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderID", "customerName", "phoneNumber", "address", "items", "total", "paymentMethod", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "productId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountPercentage", "isActive"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of all customer orders"
    },
    "coupons": {
      "schema": "Coupon",
      "description": "Collection of discount coupons"
    },
    "settings": {
      "schema": "object",
      "description": "Global store settings like delivery charges"
    }
  }
}
